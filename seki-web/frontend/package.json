{
  "name": "seki-frontend",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "build:wasm": "wasm-pack build ../../go-engine-wasm --target web --out-dir ../seki-web/static/wasm",
    "dev": "node build.mjs --watch",
    "organize-imports": "node scripts/organize-imports.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@preact/signals": "^1.3",
    "classnames": "^2.5.1",
    "preact": "10.x"
  },
  "devDependencies": {
    "esbuild": "^0.x",
    "typescript": "5.x",
    "vitest": "^4.0.18"
  }
}
