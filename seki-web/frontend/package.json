{
  "name": "seki-frontend",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "build:wasm": "wasm-pack build ../../go-engine-wasm --target web --out-dir ../seki-web/static/wasm",
    "dev": "node build.mjs --watch",
    "organize-imports": "node scripts/organize-imports.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@preact/signals": "^1.3",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "4.22.0",
    "@tensorflow/tfjs-converter": "4.22.0",
    "@tensorflow/tfjs-core": "4.22.0",
    "classnames": "^2.5.1",
    "onnxruntime-web": "1.22.0",
    "preact": "~10.29.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "5.x",
    "vite": "8.0.13",
    "vitest": "^4.1.6"
  }
}
